FROM node:18-alpine

WORKDIR /app

COPY package*.json ./

# Force install ALL deps including devDependencies (needed for tailwindcss/vite)
RUN NODE_ENV=development npm install --network-timeout=300000 || \
    NODE_ENV=development npm install --registry=https://registry.npmmirror.com --network-timeout=300000

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]