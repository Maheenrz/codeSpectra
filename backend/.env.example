# CodeSpectra Backend — copy this to .env and fill in your values
NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/codespectra_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codespectra_db
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD

JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

ANALYSIS_ENGINE_URL=http://localhost:5000
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
